{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "outDir": "dist",
    "rootDir": "..",
    "paths": {
      "#kimiflare/*": ["../src/*"],
    },
    "skipLibCheck": true,
  },
  "include": ["src/**/*", "../src/**/*"],
  "exclude": [
    "../**/*.test.*",
    "../src/index.tsx",
    "../src/app.tsx",
    "../src/ui/**",
  ],
}
