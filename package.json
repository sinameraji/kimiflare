{
  "name": "kimiflare",
  "version": "0.13.5",
  "description": "Kimiflare — a terminal coding agent powered by Kimi-K2.6 on Cloudflare Workers AI. Image understanding, plan mode, 262k context.",
  "keywords": [
    "ai",
    "cli",
    "coding-agent",
    "terminal",
    "kimi",
    "k2.6",
    "cloudflare",
    "workers-ai",
    "vision",
    "image-understanding",
    "llm",
    "code-generation",
    "tui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinameraji/kimiflare.git"
  },
  "homepage": "https://github.com/sinameraji/kimiflare#readme",
  "bugs": "https://github.com/sinameraji/kimiflare/issues",
  "license": "MIT",
  "type": "module",
  "bin": {
    "kimiflare": "bin/kimiflare.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "PLAN.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.tsx",
    "typecheck": "tsc --noEmit",
    "start": "node bin/kimiflare.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "fast-glob": "^3.3.2",
    "ink": "^7.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.0",
    "react-devtools-core": "^6.1.2",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.0",
    "@types/turndown": "^5.0.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
